{
  "name": "six-cities",
  "version": "4.0.0",
  "description": "Проект «Шесть городов» от HTML Academy",
  "keywords": [
    "rest",
    "api",
    "node.js"
  ],
  "main": "main.js",
  "scripts": {
    "start": "npm run build && node ./dist/main.js",
    "build": "tsc",
    "lint": "eslint src/ --ext .ts",
    "compile": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "ts": "ts-node",
    "cli": "tsx src/main.cli.ts",
    "start:dev": "tsx src/main.ts | pino-pretty"
  },
  "dependencies": {
    "convict": "^6.2.4",
    "convict-format-with-validator": "^6.2.0",
    "dotenv": "^16.3.1",
    "inversify": "^6.0.1",
    "pino": "^8.17.0",
    "axios": "^1.13.6",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "18.16.3",
    "@types/convict": "^6.1.1",
    "@typescript-eslint/eslint-plugin": "5.46.0",
    "@typescript-eslint/parser": "5.46.0",
    "eslint": "8.39.0",
    "eslint-config-htmlacademy": "9.1.1",
    "pino-pretty": "^10.2.0",
    "rimraf": "3.0.2",
    "ts-node": "10.9.1",
    "tsx": "^4.21.0",
    "json-server": "^1.0.0-beta.12",
    "typescript": "4.9.5"
  },
  "type": "module",
  "engines": {
    "node": "^18.0.0",
    "npm": ">=8"
  }
}
